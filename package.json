{
  "name": "clip-queue",
  "version": "3.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "typecheck": "paraglide-js compile --project ./project.inlang --outdir ./paraglide && nuxt typecheck",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "format": "oxfmt .",
    "lint": "oxfmt --check . && eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "translations:update": "pnpm dlx @inlang/cli machine translate --project ./project.inlang && pnpm format",
    "dependencies:update": "pnpm self-update && pnpm dlx nuxt upgrade --dedupe && pnpm up --latest",
    "commitlint": "commitlint --edit",
    "changeset": "changeset"
  },
  "dependencies": {
    "@nuxt/ui": "^4.9.0",
    "@pinia/nuxt": "0.11.3",
    "@tanstack/vue-table": "^8.21.3",
    "@tmi.js/chat": "^0.8.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "google-auth-library": "^10.7.0",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "video.js": "^8.23.9",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@iconify-json/lucide": "^1.2.114",
    "@iconify-json/simple-icons": "^1.2.86",
    "@inlang/paraglide-js": "2.20.1",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "4.0.3",
    "@pinia/testing": "^1.0.3",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.55.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.8.0"
}
