{
  "name": "clip-queue",
  "version": "1.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "lint": "oxfmt --check . && pnpm lint:oxlint && pnpm lint:eslint",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "pnpm lint:oxlint:fix && pnpm lint:eslint:fix",
    "lint:oxlint:fix": "oxlint . --fix",
    "lint:eslint:fix": "eslint . --fix --cache",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && vue-tsc --build",
    "deps:update": "pnpm self-update && pnpm up --latest",
    "commitlint": "commitlint --edit",
    "changeset": "changeset"
  },
  "dependencies": {
    "@primevue/icons": "^4.5.5",
    "@tmi.js/chat": "^0.7.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-primeui": "^0.6.1",
    "video.js": "^8.23.7",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@inlang/paraglide-js": "2.16.0",
    "@pinia/testing": "^1.0.3",
    "@primevue/icons": "^4.5.5",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.60.0",
    "eslint-plugin-vue": "~10.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.45.0",
    "oxlint": "~1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
