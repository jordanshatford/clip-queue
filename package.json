{
  "name": "clip-queue",
  "version": "1.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "lint": "prettier --check . && eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && vue-tsc --build",
    "deps:update": "pnpm self-update && pnpm up --latest",
    "commitlint": "commitlint --edit",
    "changeset": "changeset"
  },
  "dependencies": {
    "@primevue/icons": "^4.5.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-primeui": "^0.6.1",
    "tmi.js": "npm:@coldino/tmi.js-clientonly-fork@1.8.5-clientonly",
    "video.js": "^8.23.7",
    "vue": "catalog:",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@inlang/paraglide-js": "2.16.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@pinia/testing": "^1.0.3",
    "@primevue/icons": "^4.5.5",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tailwindcss/vite": "catalog:",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "catalog:",
    "@types/node": "catalog:",
    "@types/tmi.js": "^1.8.6",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/test-utils": "catalog:",
    "@vue/tsconfig": "catalog:",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "catalog:",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "^8.58.2",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.4",
    "vue-tsc": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "pnpm": ">=10",
    "node": ">=22"
  }
}
