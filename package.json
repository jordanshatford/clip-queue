{
  "name": "clip-queue",
  "version": "1.13.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "web": "pnpm --filter @cq/web -- ",
    "cfg": "pnpm --filter @cq/config -- ",
    "player": "pnpm --filter @cq/player -- ",
    "providers": "pnpm --filter @cq/providers -- ",
    "services": "pnpm --filter @cq/services -- ",
    "sources": "pnpm --filter @cq/sources -- ",
    "ui": "pnpm --filter @cq/ui -- ",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "format": "pnpm --recursive format",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm --recursive typecheck",
    "deps:update": "corepack use pnpm@latest && pnpm up --latest && pnpm --recursive up --latest",
    "commitlint": "commitlint --edit",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@commitlint/types": "^20.4.3",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "engines": {
    "pnpm": ">=10",
    "node": ">=20"
  }
}
