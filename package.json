{
  "name": "clip-queue",
  "version": "2.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "preview": "vite preview",
    "lint": "oxfmt --check . && pnpm lint:oxlint && pnpm lint:eslint",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "pnpm lint:oxlint:fix && pnpm lint:eslint:fix",
    "lint:oxlint:fix": "oxlint . --fix",
    "lint:eslint:fix": "eslint . --fix --cache",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && vue-tsc --build",
    "locales:update": "pnpm dlx @inlang/cli machine translate --project ./project.inlang && pnpm format",
    "deps:update": "pnpm self-update && pnpm up --latest",
    "commitlint": "commitlint --edit",
    "changeset": "changeset"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@nuxt/ui": "^4.7.1",
    "@primeuix/themes": "^2.0.3",
    "@tmi.js/chat": "^0.8.0",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "tailwindcss-primeui": "^0.6.1",
    "video.js": "^8.23.7",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@commitlint/types": "^21.0.1",
    "@iconify-json/lucide": "^1.2.107",
    "@iconify-json/simple-icons": "^1.2.82",
    "@inlang/paraglide-js": "2.18.0",
    "@pinia/testing": "^1.0.3",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.64.0",
    "eslint-plugin-vue": "~10.9.1",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.49.0",
    "oxlint": "~1.64.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.1.2"
}
